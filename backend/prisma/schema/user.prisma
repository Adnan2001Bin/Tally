/// Application user — identity, credentials, and profile preferences.
model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String   @unique
  phone          String?  @unique
  password_hash  String
  username       String   @unique
  profile_image  String?
  currency       String   @default("USD") @db.VarChar(3)
  language       String   @default("en") @db.VarChar(10)
  monthly_budget Decimal? @db.Decimal(12, 2)
  email_verified Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @updatedAt @db.Timestamptz

  auth_sessions     AuthSession[]
  personal_expenses PersonalExpense[]
  groups_created    Group[]             @relation("GroupCreator")
  group_memberships GroupMember[]
  join_requests     GroupJoinRequest[]

  @@map("users")
}
