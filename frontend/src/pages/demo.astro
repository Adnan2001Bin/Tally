---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout>
  <main class="mx-auto flex min-h-dvh max-w-lg flex-col items-center justify-center px-6 text-center">
    <div class="mb-4 flex h-[60px] w-[60px] items-center justify-center rounded-logo bg-ink">
      <span class="font-serif text-[34px] text-canvas">৳</span>
    </div>
    <h1 class="font-serif text-4xl">Demo mode</h1>
    <p class="mt-2 max-w-sm text-muted">Explore Tally without an account. Full demo experience coming soon.</p>
    <a href="/login" class="mt-8 text-sm font-semibold text-accent">Back to sign in</a>
  </main>
</BaseLayout>
